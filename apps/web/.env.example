# Backend API URL used by the Astro frontend
DJANGO_API_URL=http://localhost:8080
# Legacy fallback name; DJANGO_API_URL is preferred
CORE_API_URL=http://localhost:8080

# Stripe publishable key (PUBLIC_ prefix makes it available in client code)
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Printful webhook secret used to verify incoming webhooks
PRINTFUL_WEBHOOK_SECRET=
