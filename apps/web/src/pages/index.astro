---
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard';
import { listProducts } from '../lib/api';

const { results: products } = await listProducts();
---

<Layout>
  <section class="bg-orange-50 px-4 py-20 text-center">
    <div class="mx-auto max-w-3xl">
      <h1 class="text-4xl font-semibold tracking-tight text-neutral-900 md:text-5xl">
        Turn little drawings into lasting memories
      </h1>
      <p class="mt-4 text-lg text-neutral-600">
        Upload your child's artwork and we will print it on a beautiful ceramic mug.
      </p>
      <a
        href="/products"
        class="mt-8 inline-block rounded-lg bg-orange-700 px-8 py-3 font-medium text-white hover:bg-orange-800"
      >
        Shop mugs
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-4 py-16">
    <h2 class="text-2xl font-semibold text-neutral-900">Our mugs</h2>
    <div class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
  </section>
</Layout>
