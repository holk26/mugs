---
export const prerender = false;
import Layout from '../layouts/Layout.astro';
import ProductCard from '../components/ProductCard';
import { listProducts } from '../lib/api';

const { results: products } = await listProducts();
---

<Layout>
  <section class="px-4 py-20 text-center md:py-28">
    <div class="section">
      <div class="mx-auto max-w-3xl rounded-3xl border border-orange-100/70 bg-white/70 px-6 py-12 shadow-lg shadow-orange-100/60 backdrop-blur-sm md:px-10">
        <p class="text-sm font-semibold tracking-widest text-orange-600">Unique designs for lasting memories</p>
        <h1 class="mt-4 text-4xl font-semibold tracking-tight text-stone-900 md:text-6xl">
          Turn little drawings into lasting memories
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-stone-600 md:text-xl">
          Upload your child's artwork and we will print it on a beautiful ceramic mug.
        </p>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <a href="/products" class="btn-primary inline-flex">Shop mugs</a>
          <a href="#how-it-works" class="btn-secondary inline-flex">How it works</a>
        </div>
      </div>
    </div>
  </section>

  <section class="section py-16 md:py-24">
    <div class="flex items-end justify-between">
      <div>
        <h2 class="text-2xl font-semibold tracking-tight text-stone-900 md:text-3xl">Our mugs</h2>
        <p class="mt-2 text-stone-500">Personalized with your child's own drawing.</p>
      </div>
      <a href="/products" class="hidden text-sm font-medium text-orange-700 hover:underline md:block">
        View all
      </a>
    </div>
    <div class="mt-10 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {products.map((product) => (
        <ProductCard product={product} />
      ))}
    </div>
  </section>

  <section id="how-it-works" class="border-t border-orange-100/80 bg-gradient-to-br from-orange-50/70 via-amber-50/70 to-white px-4 py-16">
    <div class="section">
      <div class="grid gap-8 md:grid-cols-3">
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-wider text-orange-700">01</p>
          <h3 class="mt-3 text-lg font-semibold text-stone-900">Upload a drawing</h3>
          <p class="mt-2 text-sm leading-relaxed text-stone-500">
            Take a photo or scan your child's artwork and upload it on any product page.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-wider text-orange-700">02</p>
          <h3 class="mt-3 text-lg font-semibold text-stone-900">We digitize it</h3>
          <p class="mt-2 text-sm leading-relaxed text-stone-500">
            Our team cleans the lines and prepares the image for a crisp ceramic print.
          </p>
        </div>
        <div class="rounded-2xl bg-white p-6 shadow-sm">
          <p class="text-sm font-semibold uppercase tracking-wider text-orange-700">03</p>
          <h3 class="mt-3 text-lg font-semibold text-stone-900">Shipped to you</h3>
          <p class="mt-2 text-sm leading-relaxed text-stone-500">
            The finished mug is packed with care and sent straight to your door.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
