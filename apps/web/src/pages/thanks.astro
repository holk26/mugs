---
import Layout from '../layouts/Layout.astro';
import ClearCart from '../components/ClearCart';

const orderId = Astro.url.searchParams.get('order');
---

<Layout title="Thank you — Recuerdo Momentos">
  {orderId && <ClearCart client:load />}
  <section class="section py-24 text-center md:py-32">
    <div class="mx-auto max-w-xl">
      <h1 class="text-3xl font-semibold tracking-tight text-stone-900 md:text-4xl">
        Thank you for your order!
      </h1>
      <p class="mt-6 text-lg leading-relaxed text-stone-600">
        We will carefully digitize the drawing and send you updates by email.
      </p>
      {orderId && (
        <p class="mt-4 text-sm text-stone-500">
          Order reference: <span class="font-medium text-stone-900">{orderId}</span>
        </p>
      )}
      <a href="/products" class="btn-primary mt-10 inline-flex">
        Continue shopping
      </a>
    </div>
  </section>
</Layout>
